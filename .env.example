# ============================================================
# Permission Register - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment
# NEVER commit .env to version control!

# Application
APP_ENV=production
APP_URL=http://permissions.hfiu.loc
APP_TIMEZONE=Europe/Athens

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=permissions_db
DB_CHARSET=utf8mb4
DB_USER=permissions_user
DB_PASS=

# Session
SESSION_NAME=PERM_REG_SESS
SESSION_LIFETIME=7200

# LDAP / Active Directory
LDAP_HOST=ldap://your-dc.domain.loc
LDAP_PORT=389
LDAP_USE_TLS=false
LDAP_DOMAIN=domain.loc
LDAP_BASE_DN=DC=domain,DC=loc
LDAP_USERS_OU=OU=Users,DC=domain,DC=loc
LDAP_BIND_USER=CN=ServiceAccount,OU=Service Accounts,DC=domain,DC=loc
LDAP_BIND_PASS=
LDAP_ADMIN_GROUP=CN=PermRegAdmins,OU=Groups,DC=domain,DC=loc
LDAP_MANAGER_GROUP=CN=PermRegManagers,OU=Groups,DC=domain,DC=loc

# Mail (SMTP)
MAIL_FROM_ADDRESS=permissions@yourdomain.gr
MAIL_FROM_NAME=Μητρώο Δικαιωμάτων
MAIL_REPLY_TO=helpdesk@yourdomain.gr
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=10
